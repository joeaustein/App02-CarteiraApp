<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minha"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/textViewTituloApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carteira"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSair"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Sair"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/surface_variant"
            android:paddingHorizontal="16dp"
            style="@style/Widget.Carteira.Button.Secondary"
            app:cornerRadius="20dp" />

    </LinearLayout>

    <!-- Saldo Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSaldo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Accent top border via overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SALDO ATUAL"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/textViewSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="@color/saldo_positive"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/layoutSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_search_field"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toBottomOf="@id/cardSaldo"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_search"
            android:alpha="0.5"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/editTextBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar por descrição..."
            android:textColorHint="@color/text_disabled"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:background="@null"
            android:padding="10dp"
            android:inputType="text"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Filter chips -->
    <HorizontalScrollView
        android:id="@+id/scrollFiltros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="20dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutSearch"
        app:layout_constraintStart_toStartOf="parent">

        <RadioGroup
            android:id="@+id/radioGroupFiltro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <RadioButton
                android:id="@+id/radioTodos"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="  Todos  "
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:checked="true"
                android:button="@null"
                android:background="@drawable/bg_chip_selector"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:paddingHorizontal="16dp" />

            <RadioButton
                android:id="@+id/radioCreditos"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="  Créditos  "
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:button="@null"
                android:background="@drawable/bg_chip_selector"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:paddingHorizontal="16dp" />

            <RadioButton
                android:id="@+id/radioDebitos"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="  Débitos  "
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:button="@null"
                android:background="@drawable/bg_chip_selector"
                android:gravity="center"
                android:paddingHorizontal="16dp" />

        </RadioGroup>
    </HorizontalScrollView>

    <!-- Section label -->
    <TextView
        android:id="@+id/labelTransacoes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:text="Transações"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/scrollFiltros"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTransactions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="90dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/labelTransacoes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- FAB Nova Transação -->
    <Button
        android:id="@+id/btnCadastro"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:text="+ Nova Transação"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_on_accent"
        android:backgroundTint="@color/accent"
        android:paddingHorizontal="24dp"
        app:cornerRadius="28dp"
        style="@style/Widget.Carteira.Button.Primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
